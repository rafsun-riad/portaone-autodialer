DJANGO_SECRET_KEY=replace-with-a-secure-secret
DJANGO_DEBUG=True

# Local hostnames plus the public backend tunnel hostname.
# Use hostnames only here, without http:// or https://.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-backend-tunnel.trycloudflare.com

# Browser origins allowed to call the Django API during development.
# Add your local frontend origin and, if you expose the frontend too, its tunnel URL.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-tunnel.trycloudflare.com

# Trusted origins for CSRF-protected requests.
# Keep the frontend origin here, and include the public backend tunnel origin as well.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-frontend-tunnel.trycloudflare.com,https://your-backend-tunnel.trycloudflare.com

# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portaone_autodialer

EXTERNAL_SYSTEM_ORIGIN=http://localhost:8080

# When the external system must reach your backend from outside, use the backend tunnel HTTPS URL.
BACKEND_API_ORIGIN=https://your-backend-tunnel.trycloudflare.com

# Webhook callbacks for call state and prompt playback are built from this origin.
# In tunnel-based development this should normally match BACKEND_API_ORIGIN.
WEBHOOK_ORIGIN=https://your-backend-tunnel.trycloudflare.com

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
WEBHOOK_LOG_DIR=storage/webhook-logs